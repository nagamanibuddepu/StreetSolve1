# ─── Server ────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── Database ──────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/streetsolve?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ─── AI / OpenAI ───────────────────────────────────────
OPENAI_API_KEY=sk-...your_openai_key

# ─── Google Maps ───────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...your_google_maps_key

# ─── Cloudinary (Image Storage) ────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# ─── Twilio (OTP SMS) ──────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Email (SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@streetsolve.in
FROM_NAME=StreetSolve

# ─── Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# ─── Redis (optional caching) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
